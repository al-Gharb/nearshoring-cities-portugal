{
  "name": "nearshoring-cities-portugal",
  "version": "0.95.0",
  "description": "Data-driven analysis of Portugal's best cities for IT nearshoring",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run gen:rendered",
    "build": "vite build",
    "preview": "vite preview",
    "gen:rendered": "node scripts/generate_rendered_snapshots.mjs",
    "check:rendered": "node scripts/generate_rendered_snapshots.mjs --check",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint \"src/scripts/**/*.js\" vite.config.js playwright.config.js",
    "lint:css": "stylelint \"src/styles/**/*.css\"",
    "gen:fa-subset": "node scripts/generate_fa_subset.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:visual": "playwright test tests/visual/",
    "test:all": "npm run test && npm run test:visual",
    "deploy": "npm run build && npx gh-pages -d dist"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.1",
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@playwright/test": "^1.48.0",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "stylelint": "^16.19.1",
    "stylelint-config-recommended": "^15.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/al-gharb/nearshoring-cities-portugal"
  },
  "license": "UNLICENSED"
}


